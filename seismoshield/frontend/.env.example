# Copy to `.env.local` (gitignored) and fill in real values.
# Required for the interactive 360° Street View panel on /map and the
# Google Maps overlay on /exterior.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional: Google Cloud Map ID with a dark custom style
# (used by the exterior-page vector map for tilt/heading support).
NEXT_PUBLIC_GOOGLE_MAP_ID=

# Optional: SeismoShield FastAPI backend base URL (defaults to http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000
